                data: {
                    labels: ['廣達 (2382)', '緯創 (3231)', '技嘉 (2376)'],
                    datasets: [{
                        label: '目前預估本益比 (倍)',
                        data: [14.5, 10.0, 11.4], // 依據對話：廣達不到15, 緯創10, 技嘉11.4
                        backgroundColor: [
                            'rgba(99, 102, 241, 0.8)', // indigo
                            'rgba(59, 130, 246, 0.8)', // blue
                            'rgba(14, 165, 233, 0.8)'  // sky
                        ],
                        borderRadius: 8,
                        barPercentage: 0.5
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: { 
                        legend: { display: false },
                        title: { 
                            display: true, 
                            text: '外資連買：AI 伺服器低本益比優勢', 
                            font: {size: 14, weight: 'bold'},
                            color: '#334155'
                        },
                        tooltip: {
                            callbacks: {
                                label: function(context) {
                                    return '本益比約 ' + context.parsed.y + ' 倍';
                                }
                            }
                        }
                    },
                    scales: {
                        y: { 
                            beginAtZero: true, 
                            max: 20,
                            grid: { color: '#f1f5f9', drawBorder: false },
                            title: { display: true, text: '本益比 (倍)' }
                        },
                        x: { grid: { display: false, drawBorder: false } }
                    }
                }
            });
