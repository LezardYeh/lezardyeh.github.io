    <!-- Chart.js 視覺化圖表設定 -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            Chart.defaults.font.family = "'Noto Sans TC', sans-serif";
            Chart.defaults.color = '#64748b'; 

            // AI 老將本益比圖 (資料取自影片論述)
